# DeepSeek API — drives /api/summary (AI news digest) and /api/translate
# (title & summary translation for non-Chinese sources). When unset, feeds
# stay in their original language and the summary endpoint is unavailable.
DEEPSEEK_API_KEY=your_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# Optional: expose /api/debug outside local development (e.g. on Vercel
# production). Leave unset to keep the endpoint hidden in production.
# ENABLE_DEBUG=1
